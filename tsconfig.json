{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "node",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "outDir": "./site/dist",
        "rootDir": "./site/src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true
    },
    "include": [
        "site/src/**/*"
    ],
    "exclude": [
        "node_modules",
        "site/dist",
        "site/public"
    ]
}